@page "/businesses"
@rendermode InteractiveServer
@using EcoMeal1.Controllers
@using EcoMeal1.Entities_CodeFirst
@using EcoMeal1.Constants
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject AuthenticationStateProvider AuthStateProvider
@inject BusinessesController BusinessesControler
@attribute [Authorize(Roles = $"{AppRoles.Admin},{AppRoles.BusinessManager}")]

<PageTitle>Businesses</PageTitle>
<AuthorizeView Roles="Admin">
    <Authorized>
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Businesses</h1>
            <a href="/businesses/create" class="btn btn-primary">+ Add Business</a>
        </div>
    </Authorized>
</AuthorizeView>

@if(businesses is null)
{
    <p><em>Loading...</em></p>
}
else if (!businesses.Any())
{
    <p>No businesses found.</p>
}
else
{
    <div class="row g-3">
        @foreach (var b in businesses)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <img src="@b.ImageURL" class="card-img-top" alt="@b.Name" style="height:200px; object-fit:cover;" />
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">@b.Name</h5>
                            <span class="badge bg-secondary rounded-pill">@(((EcoMeal1.Enums.BusinessesTypeEnum)b.BusinessTypeId).ToString())</span>
                        </div>
                        
                        <p class="text-muted small mb-2">
                            <i class="bi bi-geo-alt-fill"></i> @b.Address
                        </p>

                        <p class="card-text">@b.Description</p>
                        @if (isAdmin || (isBusinessManager && b.OwnerId == userId))
                        {
                            <div class="mt-3 d-flex justify-content-between">
                                <a href="/businesses/create/@b.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteBusiness(b.Id)">Delete</button>
                            </div>
                        }

                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Businesses>? businesses;
    private string? userId;
    private bool isAdmin;
    private bool isBusinessManager;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        isAdmin = user.IsInRole("Admin");
        isBusinessManager = user.IsInRole("BusinessManager");

        var result = await BusinessesControler.GetAll();
        var businessesList = result.Value;

        if (isAdmin || user.IsInRole("Customer"))
        {
            businesses = businessesList;
        }
        else
        {
            businesses = businessesList?.Where(b => b.OwnerId == userId).ToList();
        }
    }

    private async Task DeleteBusiness(Guid id)
    {
        await BusinessesControler.DeleteAsync(id);
        businesses = (await BusinessesControler.GetAll()).Value;
    }

}
