@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@using EcoMeal1.Controllers
@using EcoMeal1.Services.Interfaces
@using EcoMeal1.Entities_CodeFirst
@attribute [Authorize]
@inject IBusinessesService BusinessesService
@rendermode InteractiveServer

<PageTitle>EcoMeal</PageTitle>

<div class="home-banner d-flex flex-column flex-md-row align-items-center justify-content-between shadow-sm">
    <div class="banner-text">
        <AuthorizeView>
            <Authorized>
                <span class="badge bg-white text-success mb-2 px-3 py-2 rounded-pill shadow-sm">
                    <i class="bi bi-person-circle me-1"></i> Welcome back, @(context.User.Identity?.Name?.Split('@')[0])!
                </span>
            </Authorized>
        </AuthorizeView>
        <h1 class="banner-title mb-1">Reduce food waste. <span class="text-highlight">Save your wallet.</span></h1>
        <p class="banner-subtitle mb-0 text-white-50">Join the movement against food waste with EcoMeal.</p>
    </div>
    
    <div class="banner-stats d-none d-md-flex gap-3 mt-3 mt-md-0">
        <div class="mini-stat">
            <i class="bi bi-globe-americas"></i> Reduce Waste
        </div>
        <div class="mini-stat">
            <i class="bi bi-wallet2"></i> Save Money
        </div>
    </div>
</div>


<div class="explore-section mt-5 mb-5" id="explore">
    <div class="d-flex flex-wrap gap-2 mb-4">
        <button class="btn @(selectedBusinessTypeId == null ? "btn-success" : "btn-outline-success") rounded-pill px-4" @onclick="() => FilterByType(null)">All</button>
        @foreach (var type in Enum.GetValues<EcoMeal1.Enums.BusinessesTypeEnum>())
        {
            int typeId = (int)type;
            <button class="btn @(selectedBusinessTypeId == typeId ? "btn-success" : "btn-outline-success") rounded-pill px-3" @onclick="() => FilterByType(typeId)">@type.ToString()</button>
        }
    </div>
    
    @if (businesses == null)
    {
        <p><em>Loading...</em></p>
    }
    else if (!GetFilteredBusinesses().Any())
    {
        <p>No restaurants found for the selected category.</p>
    }
    else
    {
        <div class="row g-4">
            @foreach (var b in GetFilteredBusinesses())
            {
                var availablePackages = b.Packages?.Count(p => p.Quantity > 0) ?? 0;
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 explore-card">
                        <img src="@(string.IsNullOrWhiteSpace(b.ImageURL) ? "https://placehold.co/600x400/059669/ffffff?text=EcoMeal" : b.ImageURL)" class="card-img-top" alt="@b.Name" style="height:200px; object-fit:cover;" />
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title fw-bold mb-0" style="font-family: 'Sora', sans-serif;">@b.Name</h5>
                                @if (b.BusinessType != null)
                                {
                                    <span class="badge bg-light text-dark border">@b.BusinessType.Name</span>
                                }
                            </div>
                            
                            <p class="text-muted small mb-3">
                                <i class="bi bi-geo-alt-fill text-danger"></i> @b.Address
                            </p>
                            
                            <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top">
                                <span class="text-success fw-semibold small">
                                    <i class="bi bi-box-seam"></i> @availablePackages available packages
                                </span>
                                <a href="/business/@b.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">View Details &rarr;</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<div class="how-it-works-section mt-5 pt-4 pb-5 text-center">
    <h2 class="section-title mb-5" style="font-size: 2.2rem;">How it works</h2>
    <div class="row g-4 mt-3">
        <div class="col-md-4">
            <div class="step-icon-wrapper mb-4 mx-auto">
                <i class="bi bi-search"></i>
            </div>
            <h4 class="fw-bold mb-3" style="font-family: 'Sora', sans-serif;">Search in restaurants</h4>
            <p class="text-muted px-2 px-md-4">
                Explore our list and <span class="highlight-green">discover surprise packages</span> available at nearby restaurants and stores.
            </p>
        </div>

        <div class="col-md-4">
            <div class="step-icon-wrapper mb-4 mx-auto">
                <i class="bi bi-bag-plus"></i>
            </div>
            <h4 class="fw-bold mb-3" style="font-family: 'Sora', sans-serif;">Reserve a package</h4>
            <p class="text-muted px-2 px-md-4">
                Choose your desired quantity and <span class="highlight-green">place your order instantly</span>, rescuing food from waste and saving money.
            </p>
        </div>

        <div class="col-md-4">
            <div class="step-icon-wrapper mb-4 mx-auto">
                <i class="bi bi-shop-window"></i>
            </div>
            <h4 class="fw-bold mb-3" style="font-family: 'Sora', sans-serif;">Go and Pick Up</h4>
            <p class="text-muted px-2 px-md-4">
                Go to the location within the specified timeframe, show your confirmed order and <span class="highlight-green">enjoy your delicious food!</span>
            </p>
        </div>
    </div>
</div>

<style>
    .home-banner {
        background: linear-gradient(135deg, #022c22 0%, #059669 100%);
        border-radius: 16px;
        padding: 1.5rem 2.5rem;
        color: white;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
    }
    
    .home-banner::after {
        content: '';
        position: absolute;
        top: -50px; right: -50px;
        width: 300px; height: 300px;
        background: radial-gradient(circle, rgba(52, 211, 153, 0.15) 0%, rgba(255,255,255,0) 70%);
        pointer-events: none;
        border-radius: 50%;
    }

    .banner-text {
        position: relative;
        z-index: 2;
    }

    .banner-title {
        font-size: 2rem;
        font-weight: 800;
        font-family: 'Sora', sans-serif;
        letter-spacing: -0.5px;
    }

    .text-highlight {
        color: #6ee7b7;
    }

    .banner-subtitle {
        font-size: 0.95rem;
    }

    .mini-stat {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(5px);
        -webkit-backdrop-filter: blur(5px);
        padding: 0.6rem 1.2rem;
        border-radius: 12px;
        font-size: 0.9rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        border: 1px solid rgba(255, 255, 255, 0.15);
        position: relative;
        z-index: 2;
        transition: transform 0.2s;
    }
    .mini-stat:hover {
        transform: translateY(-2px);
    }
    .mini-stat i {
        color: #a7f3d0;
        font-size: 1.2rem;
    }


    .explore-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .explore-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
    
    .how-it-works-section {
        margin-top: 4rem;
        margin-bottom: 3rem;
    }

    .step-icon-wrapper {
        width: 120px;
        height: 120px;
        background-color: #d1fae5; /* Soft mint green */
        border-radius: 50% 40% 60% 40% / 50% 60% 40% 50%; /* Playful, organic blob shape */
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3.5rem;
        color: #059669; /* Emerald green icon */
        box-shadow: 0 10px 25px rgba(16, 185, 129, 0.2);
        position: relative;
        transition: transform 0.3s;
    }
    
    .step-icon-wrapper:hover {
        transform: scale(1.05) rotate(-5deg);
    }
    
    .step-icon-wrapper i {
        position: relative;
        z-index: 2;
    }

    /* Small decorative star */
    .step-icon-wrapper::after {
        content: '✦';
        position: absolute;
        top: 0px;
        right: -15px;
        font-size: 1.5rem;
        color: #34d399; /* Bright green */
    }

    .highlight-green {
        background-color: #a7f3d0; /* Soft green highlight */
        padding: 0 6px;
        border-radius: 4px;
        font-weight: 500;
        color: #064e3b; /* Dark text for contrast */
        display: inline-block;
        line-height: 1.4;
        margin-top: 4px;
    }
</style>

@code {
    private List<Businesses>? businesses;
    private int? selectedBusinessTypeId = null;


    protected override async Task OnInitializedAsync()
    {
        businesses = await BusinessesService.GetAllWithPackagesAsync();
    }

    private void FilterByType(int? typeId)
    {
        selectedBusinessTypeId = typeId;
    }

    private IEnumerable<Businesses> GetFilteredBusinesses()
    {
        if (businesses == null) return new List<Businesses>();
        if (selectedBusinessTypeId == null) return businesses;
        return businesses.Where(b => b.BusinessTypeId == selectedBusinessTypeId);
    }
}
