@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@using EcoMeal1.Controllers
@using EcoMeal1.Services.Interfaces
@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>EcoMeal</PageTitle>

<div class="home-hero">
    <div class="hero-content">
        <AuthorizeView>
            <Authorized>
                <div class="hero-badge">Welcome back, @(context.User.Identity?.Name?.Split('@')[0])!</div>
            </Authorized>
        </AuthorizeView>
        
        <h1 class="hero-title">Save the Planet.<br/><span class="text-highlight">Save your Wallet.</span></h1>
        
        <p class="hero-subtitle">EcoMeal connects you with surplus food from local restaurants and supermarkets at heavily discounted prices. Enjoy delicious meals, reduce food waste, and make a real difference today.</p>
        
        <div class="hero-stats">
            <div class="stat-item">
                <span class="stat-icon"><i class="bi bi-globe-americas"></i></span>
                <span class="stat-text">Reduce Waste</span>
            </div>
            <div class="stat-item">
                <span class="stat-icon"><i class="bi bi-wallet2"></i></span>
                <span class="stat-text">Save Money</span>
            </div>
            <div class="stat-item">
                <span class="stat-icon"><i class="bi bi-egg-fried"></i></span>
                <span class="stat-text">Eat Well</span>
            </div>
        </div>
    </div>
</div>

<div class="dashboard-section">
    <h2 class="section-title">Quick Actions</h2>
    <div class="action-grid">
        <a href="/packages" class="premium-card">
            <div class="card-icon-wrapper bg-green">
                <i class="bi bi-box-seam"></i>
            </div>
            <div class="card-text">
                <h3>Browse Packages</h3>
                <p>Discover fresh, discounted surplus food near you.</p>
            </div>
            <div class="card-arrow"><i class="bi bi-arrow-right"></i></div>
        </a>

        <AuthorizeView Roles="Admin" Context="adminCtx">
            <Authorized>
                <a href="/businesses" class="premium-card">
                    <div class="card-icon-wrapper bg-blue">
                        <i class="bi bi-shop"></i>
                    </div>
                    <div class="card-text">
                        <h3>Manage Businesses</h3>
                        <p>View and manage all registered partner stores.</p>
                    </div>
                    <div class="card-arrow"><i class="bi bi-arrow-right"></i></div>
                </a>

                <a href="/packages/create" class="premium-card">
                    <div class="card-icon-wrapper bg-orange">
                        <i class="bi bi-plus-circle"></i>
                    </div>
                    <div class="card-text">
                        <h3>Add New Package</h3>
                        <p>Create new food rescue packages for businesses.</p>
                    </div>
                    <div class="card-arrow"><i class="bi bi-arrow-right"></i></div>
                </a>

                <a href="/admin/users" class="premium-card">
                    <div class="card-icon-wrapper bg-purple">
                        <i class="bi bi-people"></i>
                    </div>
                    <div class="card-text">
                        <h3>User Management</h3>
                        <p>Administrate user roles and system access.</p>
                    </div>
                    <div class="card-arrow"><i class="bi bi-arrow-right"></i></div>
                </a>
            </Authorized>
        </AuthorizeView>
    </div>
</div>

<style>
    /* Hero Section */
    .home-hero {
        background: linear-gradient(135deg, #0d2b1a 0%, #1a4731 100%);
        border-radius: 20px;
        padding: 4rem 3.5rem;
        color: white;
        margin-bottom: 3rem;
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(26, 71, 49, 0.15);
    }
    
    .home-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(74, 222, 128, 0.15) 0%, rgba(255,255,255,0) 70%);
        border-radius: 50%;
        pointer-events: none;
    }

    .hero-content {
        position: relative;
        z-index: 1;
        max-width: 650px;
    }

    .hero-badge {
        display: inline-block;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 0.5rem 1.2rem;
        border-radius: 50px;
        font-size: 0.9rem;
        font-weight: 500;
        margin-bottom: 2rem;
        color: #e0f5ea;
    }

    .hero-title {
        font-size: 3.5rem;
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 1.5rem;
        font-family: 'Sora', sans-serif;
        letter-spacing: -1px;
    }

    .text-highlight {
        color: #4ade80; /* bright green */
    }

    .hero-subtitle {
        font-size: 1.15rem;
        line-height: 1.6;
        color: #a7f3d0;
        margin-bottom: 2.5rem;
        max-width: 580px;
    }

    .hero-stats {
        display: flex;
        gap: 2.5rem;
    }

    .stat-item {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-weight: 600;
        font-size: 1rem;
        color: #fff;
    }
    .stat-icon {
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: rgba(74, 222, 128, 0.15);
        border-radius: 50%;
        color: #4ade80;
    }

    /* Dashboard Actions */
    .dashboard-section {
        margin-top: 2rem;
    }

    .section-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 1.5rem;
        font-family: 'Sora', sans-serif;
    }

    .action-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
    }

    .premium-card {
        display: flex;
        align-items: center;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 1.5rem;
        text-decoration: none !important;
        color: inherit !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    }

    .premium-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        border-color: #4ade80;
    }

    .card-icon-wrapper {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        margin-right: 1.25rem;
        flex-shrink: 0;
    }

    .bg-green { background: #dcfce7; color: #16a34a; }
    .bg-blue { background: #dbeafe; color: #2563eb; }
    .bg-orange { background: #ffedd5; color: #ea580c; }
    .bg-purple { background: #f3e8ff; color: #9333ea; }

    .card-text h3 {
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0 0 0.3rem 0;
        color: #111827;
        font-family: 'Sora', sans-serif;
    }

    .card-text p {
        font-size: 0.88rem;
        color: #6b7280;
        margin: 0;
        line-height: 1.4;
    }

    .card-arrow {
        margin-left: auto;
        color: #9ca3af;
        font-size: 1.3rem;
        transition: transform 0.2s, color 0.2s;
    }

    .premium-card:hover .card-arrow {
        transform: translateX(4px);
        color: #16a34a;
    }
    
</style>
