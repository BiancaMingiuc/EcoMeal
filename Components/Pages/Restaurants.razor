@page "/restaurants"
@attribute [StreamRendering]

<PageTitle>Restaurants</PageTitle>

<h1>Restaurants</h1>
<div class="mb-3">
    <a href="/businesses/create" class="btn btn-primary">+ Create Business</a>
</div>

@if (packages == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row g-3">
        @foreach (var pkg in packages)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@pkg.Title</h5>
                        <p class="card-text">@pkg.RestaurantName</p>
                        <p class="card-text">Expira: @pkg.ExpiresAt.ToShortDateString()</p>
                        <p class="card-text">
                            <s>@pkg.OriginalPrice.ToString("0") lei</s>
                            <strong>@pkg.DiscountedPrice.ToString("0") lei</strong>
                        </p>
                        <p class="card-text">Cantitate: @pkg.QuantityAvailable</p>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private FoodPackageItem[]? packages;

    protected override async Task OnInitializedAsync()
    {
        await Task.Delay(500);

        var restaurantNames = new[] { "Brutarie", "Brasserie", "Pizza", "Bisanco Bistro", "Fresh Corner" };
        var titles = new[] { "Pachet patiserie", "Pachet meniul zilei", "Pachet pizza", "Pachet supe", "Pachet salate" };

        packages = Enumerable.Range(1, 5).Select(index =>
        {
            var original = Random.Shared.Next(25, 70);
            var discount = Random.Shared.Next(35, 65);

            return new FoodPackageItem
            {
                RestaurantName = restaurantNames[Random.Shared.Next(restaurantNames.Length)],
                Title = titles[Random.Shared.Next(titles.Length)],
                OriginalPrice = original,
                DiscountedPrice = original * (100 - discount) / 100m,
                QuantityAvailable = Random.Shared.Next(0, 5),
                ExpiresAt = DateTime.Today.AddDays(Random.Shared.Next(0, 3))
            };
        }).ToArray();
    }

    private class FoodPackageItem
    {
        public string RestaurantName { get; set; } = "";
        public string Title { get; set; } = "";
        public decimal OriginalPrice { get; set; }
        public decimal DiscountedPrice { get; set; }
        public int QuantityAvailable { get; set; }
        public DateTime ExpiresAt { get; set; }
    }
}
