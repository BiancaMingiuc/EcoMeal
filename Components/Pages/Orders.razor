@page "/orders"
@rendermode InteractiveServer
@using EcoMeal1.Entities_CodeFirst
@using EcoMeal1.Services.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IOrderService OrderService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Orders</PageTitle>

<AuthorizeView Roles="Admin">
    <Authorized>
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Orders</h1>
        </div>
    </Authorized>
</AuthorizeView>

<div class="row mb-4">
    <div class="col-md-4">
        <label for="statusFilter" class="form-label fw-bold">Filter by Status:</label>
        <select id="statusFilter" class="form-select" @bind="selectedStatusFilter" @bind:after="ApplyFilter">
            <option value="0">All Statuses</option>
            <option value="1">Pending</option>
            <option value="2">Confirmed</option>
            <option value="3">Picked Up</option>
            <option value="4">Cancelled</option>
        </select>
    </div>
</div>

@if (orders == null)
{
    <p><em>Loading...</em></p>
}
else if (!orders.Any())
{
    <p>No orders found.</p>
}
else
{
    <div class="accordion" id="ordersAccordion">
        @foreach (var order in filteredOrders)
        {
            var accordionId = $"collapse{order.Id:N}";
            var headingId = $"heading{order.Id:N}";

            <div class="accordion-item mb-3 border rounded shadow-sm">
                <h2 class="accordion-header" id="@headingId">
                    <button class="accordion-button @(expandedOrders.Contains(order.Id) ? "" : "collapsed")" type="button" @onclick="() => ToggleOrder(order.Id)">
                        <div class="d-flex w-100 justify-content-between align-items-center me-3">
                            <strong>Order #@order.OrderNumber @(isAdmin ? $"- {order.User?.Email}" : "")</strong>
                            <span class="badge @GetBadgeClass(order.StatusId) rounded-pill">@(order.Status?.Name ?? "Pending")</span>
                        </div>
                    </button>
                </h2>
                <div id="@accordionId" class="accordion-collapse collapse @(expandedOrders.Contains(order.Id) ? "show" : "")" aria-labelledby="@headingId" data-bs-parent="#ordersAccordion">
                    <div class="accordion-body">
                        @if (order.OrderPackages == null || !order.OrderPackages.Any())
                        {
                            <p class="text-muted">This order contains no packages.</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Package</th>
                                            <th>Quantity</th>
                                            <th>Restaurant</th>
                                            <th>Pickup Time</th>
                                            <th>Description</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var op in order.OrderPackages)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@(op.Package?.Name ?? "N/A")</strong>
                                                </td>
                                                <td>@op.Quantity</td>
                                                <td>
                                                    <i class="bi bi-shop text-muted"></i> @(op.Package?.Businesses?.Name ?? "N/A")
                                                </td>
                                                <td>
                                                    @if (op.Package != null)
                                                    {
                                                        <span>@op.Package.PickupStart.ToString("dd/MM HH:mm") - @op.Package.PickupEnd.ToString("HH:mm")</span>
                                                    }
                                                    else
                                                    {
                                                        <span>N/A</span>
                                                    }
                                                </td>
                                                <td class="text-muted small">
                                                    @(op.Package?.Description ?? "N/A")
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        <div class="mt-3 text-end">
                            @if (order.StatusId == 1) // Pending
                            {
                                if (isBusinessManager || isAdmin)
                                {
                                    <button class="btn btn-sm btn-success me-2" @onclick="() => ConfirmOrder(order.Id)">Confirm Order</button>
                                }
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => CancelOrder(order.Id)">Cancel Order</button>
                            }
                            else if (order.StatusId == 2) // Confirmed
                            {
                                if (isCustomer || isAdmin)
                                {
                                    <button class="btn btn-sm btn-primary" @onclick="() => PickUpOrder(order.Id)">Mark as Picked Up</button>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Order>? orders;
    private List<Order> filteredOrders = new();
    private bool isAdmin;
    private bool isBusinessManager;
    private bool isCustomer;
    private HashSet<Guid> expandedOrders = new();
    private int selectedStatusFilter = 0;

    private void ToggleOrder(Guid id)
    {
        if (expandedOrders.Contains(id))
            expandedOrders.Remove(id);
        else
            expandedOrders.Add(id);
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isAdmin = authState.User.IsInRole("Admin");
        isBusinessManager = authState.User.IsInRole("BusinessManager");
        isCustomer = authState.User.IsInRole("Customer");
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (user.IsInRole("Admin"))
        {
            orders = await OrderService.GetAllAsync();
        }
        else if (user.IsInRole("BusinessManager"))
        {
            orders = await OrderService.GetByBusinessOwnerIdAsync(userId ?? string.Empty);
        }
        else
        {
            orders = await OrderService.GetByUserIdAsync(userId ?? string.Empty);
        }
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        if (orders == null) return;
        
        if (selectedStatusFilter == 0)
        {
            filteredOrders = orders.ToList();
        }
        else
        {
            filteredOrders = orders.Where(o => o.StatusId == selectedStatusFilter).ToList();
        }
    }

    private async Task CancelOrder(Guid id)
    {
        await OrderService.CancelAsync(id);
        await LoadOrders();
    }

    private async Task ConfirmOrder(Guid id)
    {
        await OrderService.ConfirmAsync(id);
        await LoadOrders();
    }

    private async Task PickUpOrder(Guid id)
    {
        await OrderService.PickUpAsync(id);
        await LoadOrders();
    }

    private string GetBadgeClass(int statusId)
    {
        return statusId switch
        {
            1 => "bg-warning text-dark", // Pending
            2 => "bg-info", // Confirmed
            3 => "bg-success", // PickedUp
            4 => "bg-danger", // Cancelled
            _ => "bg-secondary"
        };
    }
}