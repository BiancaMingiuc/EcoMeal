@page "/packages"
@rendermode InteractiveServer
@using EcoMeal1.Entities_CodeFirst
@using EcoMeal1.Controllers
@using EcoMeal1.Services
@using EcoMeal1.Services.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject PackageController PackageController
@attribute [Authorize(Roles = "Admin,Customer")]
@inject IOrderService OrderService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Packages</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Packages</h1>
    <AuthorizeView Roles="Admin,BusinessManager">
        <Authorized>
            <a href="/packages/create" class="btn btn-primary">+ Add Package</a>
        </Authorized>
    </AuthorizeView>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
    </div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success" role="alert">
        @successMessage
    </div>
}

@if (packages == null)
{
    <p><em>Loading...</em></p>
}
else if (!packages.Any())
{
    <p>No packages found.</p>
}
else
{
    <div class="row g-3">
        @foreach (var pkg in packages)
        {
            if (!isAdminOrManager && pkg.Quantity<=0)
            {
                continue;
            }
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <img src="@pkg.ImageURL" class="card-img-top" alt="@pkg.Name" style="height:200px; object-fit:cover;" />
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <h5 class="card-title mb-0">@pkg.Name</h5>
                                @if (pkg.PackageType != null)
                                {
                                    <span class="badge bg-secondary mt-1">@pkg.PackageType.Name</span>
                                }
                            </div>
                            <span class="badge bg-success rounded-pill">@pkg.Price.ToString("0.00") RON</span>
                        </div>
                        
                        @if (pkg.Businesses != null)
                        {
                            <p class="text-muted small mb-2">
                                <i class="bi bi-shop"></i> @pkg.Businesses.Name
                            </p>
                        }

                        <p class="card-text">@pkg.Description</p>
                        
                        <div class="mt-auto">
                            <hr class="my-2"/>
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <small class="text-muted">
                                    <i class="bi bi-box-seam"></i> @pkg.Quantity available
                                </small>
                                <small class="text-muted">
                                    <i class="bi bi-clock"></i> @pkg.PickupStart.ToString("HH:mm") - @pkg.PickupEnd.ToString("HH:mm")
                                </small>
                            </div>
                            <div class="d-flex justify-content-end align-items-center">
                                <small class="text-danger fw-semibold" style="font-size: 0.8rem;">
                                    <i class="bi bi-exclamation-circle"></i> Exp: @pkg.ExpirationDate.ToString("dd MMM yyyy, HH:mm")
                                </small>
                            </div>
                        </div>
                        <AuthorizeView Roles="Admin,BusinessManager">
                            <Authorized>
                                <div class="mt-3 d-flex justify-content-between">
                                    <a href="/packages/create/@pkg.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeletePackage(pkg.Id)">Delete</button>
                                </div>
                            </Authorized>
                        </AuthorizeView>

                        <div class="mt-3">
                            <label class="form-label small">Quantity</label>
                            <input type="number" @bind="selectedQuantities[pkg.Id]" min="1" max="@pkg.Quantity" class="form-control mb-2" />
                            <button class="btn btn-success w-100" @onclick="() => PlaceDirectOrder(pkg)">Order Now</button>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Package>? packages;
    private Dictionary<Guid, int> selectedQuantities = new();
    private string? errorMessage;
    private string? successMessage;
    private bool isAdminOrManager;

    protected override async Task OnInitializedAsync()
    {
        var result = await PackageController.GetAll();
        packages = result.Value;
        
        if (packages != null)
        {
            foreach(var p in packages)
            {
                selectedQuantities[p.Id] = 1;
            }
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        isAdminOrManager = user.IsInRole("Admin") || user.IsInRole("BusinessManager");
    }

    private async Task DeletePackage(Guid id)
    {
        await PackageController.DeleteAsync(id);
        var result = await PackageController.GetAll();
        packages = result.Value;
    }

    private async Task PlaceDirectOrder(Package package)
    {
        errorMessage = null;
        successMessage = null;
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        
        if (!user.Identity?.IsAuthenticated ?? true)
        {
            errorMessage = "You must be logged in to place an order.";
            return;
        }

        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId))
        {
            errorMessage = "Could not find user ID.";
            return;
        }

        int quantityToOrder = selectedQuantities.ContainsKey(package.Id) ? selectedQuantities[package.Id] : 1;

        try
        {
            var newOrder = new Order
            {
                Id = Guid.NewGuid(),
                UserId = userId,
                BusinessId = package.BusinessId,
                OrderNumber = "CMD-" + new Random().Next(10000, 99999),
                StatusId = 1 
            };

            newOrder.OrderPackages.Add(new OrderPackage
            {
                Id = Guid.NewGuid(),
                OrderId = newOrder.Id,
                PackageId = package.Id,
                Quantity = quantityToOrder
            });

            await OrderService.AddAsync(newOrder);
            
            successMessage = "Order placed successfully!";
            
            var result = await PackageController.GetAll();
            packages = result.Value;
            
            // reset quantity
            selectedQuantities[package.Id] = 1;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error placing order: {ex.Message}";
        }
    }
}
