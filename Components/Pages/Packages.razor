@page "/packages"
@rendermode InteractiveServer
@using EcoMeal1.Entities_CodeFirst
@using EcoMeal1.Controllers
@using EcoMeal1.Services
@using EcoMeal1.Services.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject PackageController PackageController
@attribute [Authorize(Roles = "Admin,Customer,BusinessManager")]
@inject IOrderService OrderService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Packages</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Packages</h1>
    <AuthorizeView Roles="Admin,BusinessManager">
        <Authorized>
            <a href="/packages/create" class="btn btn-primary">+ Add Package</a>
        </Authorized>
    </AuthorizeView>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
    </div>
}


@if (showOrderSuccessPopup)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.6); backdrop-filter: blur(4px); z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg text-center p-4 rounded-4">
                <div class="modal-body">
                    <div class="success-animation mb-3">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
                    </div>
                    <h3 class="fw-bold mb-3" style="font-family: 'Sora', sans-serif;">Order Confirmed!</h3>
                    <p class="text-muted fs-5 mb-4">Your package has been successfully reserved. Check your Orders page for details!</p>
                    <button class="btn btn-success btn-lg px-5 rounded-pill shadow-sm" @onclick="ClosePopup">Awesome!</button>
                </div>
            </div>
        </div>
    </div>
}

<div class="d-flex flex-wrap align-items-center gap-3 mb-4">
    <div class="d-flex flex-wrap gap-2">
        <button class="btn @(selectedBusinessTypeId == null ? "btn-success" : "btn-outline-success") rounded-pill px-4" @onclick="() => FilterByType(null)">All</button>
        @foreach (var type in Enum.GetValues<EcoMeal1.Enums.BusinessesTypeEnum>())
        {
            int typeId = (int)type;
            <button class="btn @(selectedBusinessTypeId == typeId ? "btn-success" : "btn-outline-success") rounded-pill px-3" @onclick="() => FilterByType(typeId)">@type.ToString()</button>
        }
    </div>

    <div class="ms-md-auto d-flex align-items-center gap-2">
        <span class="text-muted small fw-bold text-uppercase text-nowrap">Package Type:</span>
        <select class="form-select rounded-pill border-success" style="width: 220px;" @onchange="OnPackageTypeChanged">
            <option value="">All Types</option>
            @foreach (var type in Enum.GetValues<EcoMeal1.Enums.PackageTypeEnum>())
            {
                <option value="@((int)type)">@type.ToString()</option>
            }
        </select>
    </div>
</div>

@if (packages == null)
{
    <p><em>Loading...</em></p>
}
else if (!GetFilteredPackages().Any())
{
    <p>No packages found for the selected category.</p>
}
else
{
    <div class="row g-3">
        @foreach (var pkg in GetFilteredPackages())
        {
            if (!isAdminOrManager && pkg.Quantity<=0)
            {
                continue;
            }
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm">
                    <img src="@(string.IsNullOrWhiteSpace(pkg.ImageURL) ? "https://placehold.co/600x400/059669/ffffff?text=EcoMeal" : pkg.ImageURL)" class="card-img-top" alt="@pkg.Name" style="height:200px; object-fit:cover;" />
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <h5 class="card-title mb-0">@pkg.Name</h5>
                                @if (pkg.PackageType != null)
                                {
                                    <span class="badge bg-secondary mt-1">@pkg.PackageType.Name</span>
                                }
                            </div>
                            <span class="badge bg-success rounded-pill">@pkg.Price.ToString("0.00") RON</span>
                        </div>
                        
                        @if (pkg.Businesses != null)
                        {
                            <p class="text-muted small mb-2">
                                <i class="bi bi-shop"></i> @pkg.Businesses.Name
                            </p>
                        }

                        <p class="card-text">@pkg.Description</p>
                        
                        <div class="mt-auto">
                            <hr class="my-2"/>
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <small class="text-muted">
                                    <i class="bi bi-box-seam"></i> @pkg.Quantity available
                                </small>
                                <small class="text-muted">
                                    <i class="bi bi-clock"></i> @pkg.PickupStart.ToString("HH:mm") - @pkg.PickupEnd.ToString("HH:mm")
                                </small>
                            </div>
                            <div class="d-flex justify-content-end align-items-center">
                                <small class="text-danger fw-semibold" style="font-size: 0.8rem;">
                                    <i class="bi bi-exclamation-circle"></i> Exp: @pkg.ExpirationDate.ToString("dd MMM yyyy, HH:mm")
                                </small>
                            </div>
                        </div>
                        @if (isAdmin || (pkg.Businesses?.OwnerId == currentUserId))
                        {
                            <div class="mt-3 d-flex justify-content-between">
                                <a href="/packages/create/@pkg.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeletePackage(pkg.Id)">Delete</button>
                            </div>
                        }

                        <div class="mt-3">
                            <label class="form-label small">Quantity</label>
                            <input type="number" @bind="selectedQuantities[pkg.Id]" min="1" max="@pkg.Quantity" class="form-control mb-2" />
                            <button class="btn btn-success w-100" @onclick="() => PlaceDirectOrder(pkg)">Order Now</button>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Package>? packages;
    private int? selectedBusinessTypeId = null;
    private int? selectedPackageTypeId = null;
    private Dictionary<Guid, int> selectedQuantities = new();
    private string? errorMessage;
    private bool isAdminOrManager;
    private bool isAdmin;
    private bool isBusinessManager;
    private string? currentUserId;
    private bool showOrderSuccessPopup = false;

    private void ClosePopup()
    {
        showOrderSuccessPopup = false;
    }

    private void FilterByType(int? typeId)
    {
        selectedBusinessTypeId = typeId;
    }

    private void OnPackageTypeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int typeId))
        {
            selectedPackageTypeId = typeId;
        }
        else
        {
            selectedPackageTypeId = null;
        }
    }

    private IEnumerable<Package> GetFilteredPackages()
    {
        if (packages == null) return new List<Package>();
        
        var query = packages.AsEnumerable();
        
        if (selectedBusinessTypeId != null)
        {
            query = query.Where(p => p.Businesses != null && p.Businesses.BusinessTypeId == selectedBusinessTypeId);
        }
        
        if (selectedPackageTypeId != null)
        {
            query = query.Where(p => p.PackageTypeId == selectedPackageTypeId);
        }
        
        return query;
    }



    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        isAdmin = user.IsInRole("Admin");
        isBusinessManager = user.IsInRole("BusinessManager");
        isAdminOrManager = isAdmin || isBusinessManager;
        currentUserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        var result = await PackageController.GetAll();
        packages = result.Value;

        if (isBusinessManager && !isAdmin)
        {
            packages = packages?.Where(p => p.Businesses?.OwnerId == currentUserId).ToList();
        }
        
        if (packages != null)
        {
            foreach(var p in packages)
            {
                selectedQuantities[p.Id] = 1;
            }
        }
    }

    private async Task DeletePackage(Guid id)
    {
        await PackageController.DeleteAsync(id);
        var result = await PackageController.GetAll();
        packages = result.Value;
    }

    private async Task PlaceDirectOrder(Package package)
    {
        errorMessage = null;
        
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        
        if (!user.Identity?.IsAuthenticated ?? true)
        {
            errorMessage = "You must be logged in to place an order.";
            return;
        }

        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(userId))
        {
            errorMessage = "Could not find user ID.";
            return;
        }

        int quantityToOrder = selectedQuantities.ContainsKey(package.Id) ? selectedQuantities[package.Id] : 1;

        try
        {
            var newOrder = new Order
            {
                Id = Guid.NewGuid(),
                UserId = userId,
                BusinessId = package.BusinessId,
                OrderNumber = "CMD-" + new Random().Next(10000, 99999),
                StatusId = 1 
            };

            newOrder.OrderPackages.Add(new OrderPackage
            {
                Id = Guid.NewGuid(),
                OrderId = newOrder.Id,
                PackageId = package.Id,
                Quantity = quantityToOrder
            });

            await OrderService.AddAsync(newOrder);
            
            showOrderSuccessPopup = true;
            
            var result = await PackageController.GetAll();
            packages = result.Value;
            
            // reset quantity
            selectedQuantities[package.Id] = 1;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error placing order: {ex.Message}";
        }
    }
}

<style>
    @@keyframes scaleIn {
        0% { transform: scale(0); opacity: 0; }
        60% { transform: scale(1.2); }
        100% { transform: scale(1); opacity: 1; }
    }
    .success-animation i {
        animation: scaleIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        display: inline-block;
    }
</style>
