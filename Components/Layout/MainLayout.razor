@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    <span class="topbar-user">
                        <span class="topbar-avatar">@(string.IsNullOrEmpty(context.User.Identity?.Name) ? "U" : context.User.Identity!.Name.Substring(0, 1).ToUpper())</span>
                        <span class="topbar-name">@context.User.Identity?.Name</span>
                    </span>
                    <a href="api/auth/logout" class="topbar-logout" style="text-decoration:none; display:flex; align-items:center;">Logout</a>
                </Authorized>
                <NotAuthorized>
                    <a href="/account/login" class="btn btn-outline-primary btn-sm">Login</a>
                    <a href="/account/register" class="btn btn-primary btn-sm ms-2">Register</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unexpected error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">✕</span>
</div>